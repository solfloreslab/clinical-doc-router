{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LabExtraction",
  "description": "Output schema for the laboratory data extractor prompt",
  "type": "object",
  "required": ["patient", "date", "ordering_physician", "tests", "critical_values", "data_quality"],
  "properties": {
    "patient": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Report date in YYYY-MM-DD format"
    },
    "ordering_physician": { "type": "string" },
    "service": { "type": ["string", "null"] },
    "sections": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of report sections found (e.g., BIOQUÍMICA, HEMATOLOGÍA)"
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value", "unit", "flag"],
        "properties": {
          "name": { "type": "string" },
          "value": { "type": ["number", "null"] },
          "unit": { "type": "string" },
          "reference_low": { "type": ["number", "null"] },
          "reference_high": { "type": ["number", "null"] },
          "flag": {
            "type": "string",
            "enum": ["normal", "low", "high", "critical_low", "critical_high"]
          },
          "qualitative_result": {
            "type": ["string", "null"],
            "description": "For non-numeric results (e.g., Positive/Negative)"
          }
        }
      }
    },
    "critical_values": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test", "value", "unit", "reference_range", "deviation"],
        "properties": {
          "test": { "type": "string" },
          "value": { "type": "number" },
          "unit": { "type": "string" },
          "reference_range": { "type": "string" },
          "deviation": { "type": "string" }
        }
      }
    },
    "data_quality": {
      "type": "string",
      "enum": ["complete", "partial", "poor"]
    }
  }
}
