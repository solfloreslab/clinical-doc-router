{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClassifierOutput",
  "description": "Output schema for the clinical document classifier prompt",
  "type": "object",
  "required": ["category", "summary", "critical_flags", "language", "completeness"],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["laboratory", "radiology", "clinical_note", "prescription", "administrative", "interconsultation"],
      "description": "Document type classification"
    },
    "summary": {
      "type": "string",
      "description": "One-sentence description of the document content"
    },
    "critical_flags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Array of critical values or urgent findings detected"
    },
    "language": {
      "type": "string",
      "enum": ["es", "en", "mixed"],
      "description": "Primary language of the document"
    },
    "completeness": {
      "type": "string",
      "enum": ["complete", "incomplete"],
      "description": "Whether the document appears whole or truncated"
    }
  },
  "additionalProperties": false
}
