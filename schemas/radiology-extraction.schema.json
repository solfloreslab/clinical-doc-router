{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RadiologyExtraction",
  "description": "Output schema for the radiology report extractor prompt",
  "type": "object",
  "required": ["patient", "date", "study", "findings", "impression", "data_quality"],
  "properties": {
    "patient": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": { "type": "string" },
        "id": { "type": "string" }
      }
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "ordering_physician": { "type": ["string", "null"] },
    "service": { "type": ["string", "null"] },
    "study": {
      "type": "object",
      "required": ["modality", "modality_description", "body_region"],
      "properties": {
        "modality": {
          "type": "string",
          "enum": ["XR", "CT", "MRI", "US", "NM", "other"],
          "description": "Standard modality abbreviation"
        },
        "modality_description": {
          "type": "string",
          "description": "Full modality description as written in the report"
        },
        "body_region": { "type": "string" },
        "technique": { "type": ["string", "null"] }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["structure", "observation", "significance"],
        "properties": {
          "structure": { "type": "string" },
          "observation": { "type": "string" },
          "significance": {
            "type": "string",
            "enum": ["normal", "abnormal", "incidental"]
          }
        }
      }
    },
    "impression": { "type": "string" },
    "recommendation": { "type": ["string", "null"] },
    "reporting_physician": { "type": ["string", "null"] },
    "data_quality": {
      "type": "string",
      "enum": ["complete", "partial", "poor"]
    }
  }
}
